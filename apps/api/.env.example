# ============================================================
# EP-Product API — Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# ── Database ─
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ep_product?schema=public"

# ── Redis ────
REDIS_URL="redis://localhost:6379"

# ── JWT Authentication 
# IMPORTANT: Generate strong random secrets for production
# Use: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Minimum 32 characters each. NEVER use the defaults in production.
JWT_ACCESS_SECRET="replace-with-64-char-random-hex-string"
JWT_REFRESH_SECRET="replace-with-64-char-random-hex-string"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# ── Cloudinary (REQUIRED) 
# Sign up at https://cloudinary.com/ (free tier: 25 credits/month)
# Find keys at: Dashboard > Account Details
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ── AI Provider (REQUIRED)
# OpenAI — https://platform.openai.com/
# All tiers use AI generation. The template is a style reference —
# the AI generates a new poster matching the style with text/logo
# artistically integrated. Models are configured via admin UI.
OPENAI_API_KEY=""

# ── Seedance video provider (REQUIRED for /videos)
# ByteDance Seedance 2.0 via BytePlus ModelArk.
# Get an API key: https://console.byteplus.com/auth/login + activate Seedance models.
# China-region alternative: set SEEDANCE_BASE_URL to https://ark.cn-beijing.volces.com/api/v3
# (and re-map shared/constants/video.ts model IDs from "dreamina-" to "doubao-").
SEEDANCE_API_KEY=""
SEEDANCE_BASE_URL="https://ark.ap-southeast.bytepluses.com/api/v3"
# Hard cap on how long the worker waits for one Seedance task (ms).
# 540s = 9 min; the per-job timeout is 10 min, so we leave ~1 min for stitch + upload.
SEEDANCE_POLL_MAX_WAIT_MS=540000

# ── Razorpay (Web payments) 
# Sign up at https://dashboard.razorpay.com/
# Get API keys from: Dashboard → Settings → API Keys
# Webhook secret: Dashboard → Settings → Webhooks → Create webhook
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# ── Apple Subscriptions
# Only needed for live Apple In-App Purchase testing
# Requires Apple Developer account ($99/year)
APPLE_KEY_ID=""
APPLE_ISSUER_ID=""
APPLE_BUNDLE_ID=""
APPLE_PRIVATE_KEY=""
APPLE_ENVIRONMENT="Sandbox"
# Optional for Sign in with Apple. For iOS this is usually the bundle ID;
# for web it is the Services ID. Falls back to APPLE_BUNDLE_ID if empty.
APPLE_SIGN_IN_CLIENT_ID=""

# ── Application
NODE_ENV="development"
API_PORT=4000
API_URL="http://localhost:4000"
WEB_URL="http://localhost:3000"
CORS_ORIGINS="http://localhost:3000"

# ── Worker ──
WORKER_CONCURRENCY=3
WORKER_MAX_MEMORY_MB=512
# Optional override for the video worker (defaults to ceil(WORKER_CONCURRENCY/2), min 1).
# Each video job is heavier than an image job (ffmpeg + clip buffers in RAM).
# VIDEO_WORKER_CONCURRENCY=2

# ── Rate Limiting ────────
RATE_LIMIT_GLOBAL_PER_MIN=100
RATE_LIMIT_AUTH_PER_MIN=10
RATE_LIMIT_GENERATION_PER_MIN=5
