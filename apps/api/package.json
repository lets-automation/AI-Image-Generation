{
  "name": "@ep/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/server.js",
    "worker": "tsx --env-file=.env src/queues/worker-entry.ts",
    "worker:prod": "node --max-old-space-size=512 --expose-gc dist/queues/worker-entry.js",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@ep/shared": "*",
    "@napi-rs/canvas": "^0.1.62",
    "@prisma/client": "^6.2.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.30.0",
    "cloudinary": "^2.5.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "razorpay": "^2.9.6",
    "sharp": "^0.33.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/geoip-lite": "^1.4.4",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.0.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.2.0",
    "prisma-json-types-generator": "^3.1.0",
    "rimraf": "^6.0.0",
    "tsc-alias": "^1.8.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
