# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ep_product?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# AI Provider (REQUIRED)
# OpenAI — https://platform.openai.com/
OPENAI_API_KEY=""

# Seedance video provider (REQUIRED for /videos) — BytePlus ModelArk
# Get key at https://console.byteplus.com/ and activate Seedance models.
SEEDANCE_API_KEY=""
SEEDANCE_BASE_URL="https://ark.ap-southeast.bytepluses.com/api/v3"
SEEDANCE_POLL_MAX_WAIT_MS=540000

# Razorpay (Web payments) — https://dashboard.razorpay.com/
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# Apple Subscriptions (optional)
APPLE_KEY_ID=""
APPLE_ISSUER_ID=""
APPLE_BUNDLE_ID=""
APPLE_PRIVATE_KEY=""
APPLE_ENVIRONMENT="Sandbox"
# Optional for Sign in with Apple. For iOS this is usually the bundle ID;
# for web it is the Services ID. Falls back to APPLE_BUNDLE_ID if empty.
APPLE_SIGN_IN_CLIENT_ID=""

# Application
NODE_ENV="development"
API_PORT=4000
API_URL="http://localhost:4000"
WEB_URL="http://localhost:3000"
CORS_ORIGINS="http://localhost:3000"

# Worker
WORKER_CONCURRENCY=3
WORKER_MAX_MEMORY_MB=512
# Optional video worker override (defaults to ceil(WORKER_CONCURRENCY/2), min 1)
# VIDEO_WORKER_CONCURRENCY=2

# Rate Limiting
RATE_LIMIT_GLOBAL_PER_MIN=100
RATE_LIMIT_AUTH_PER_MIN=10
RATE_LIMIT_GENERATION_PER_MIN=5
